# Coordinator API
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
COORDINATOR_BASE_URL=http://localhost:8080

# Dev defaults (in-memory storage — no Supabase required)
USE_FAKE_STORAGE=true

# API keys (Bearer tokens)
WEB_API_KEY=dev-web-key
WORKER_API_KEY=dev-worker-key

# Supabase (required when USE_FAKE_STORAGE=false)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AUDIO_BUCKET=inference-audio
SUPABASE_PHOTO_BUCKET=inference-photos

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173
